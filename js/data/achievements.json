{
  "$schema": "Achievement definitions for Tower",
  "description": "Each achievement has a unique id, display fields, an unlock condition, and optional stat threshold.",
  "conditionTypes": {
    "stat_ge": "Fires when a stat reaches or exceeds the given threshold.",
    "upgrade_level": "Fires when a specific upgrade reaches the given level.",
    "prestige_count": "Fires when prestige reset count reaches threshold.",
    "max_height_ge": "Fires when all-time maxHeight reaches threshold."
  },
